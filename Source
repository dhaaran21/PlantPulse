# ------ 5 OLED Display Function ----------

def oled_screen(line1 = "", line2 = "", delay = oled_delay):
    oled.fill(0)                                    # clears OLED screen
    oled.text(str(line1)[:16], 0, 0)                # 0,0 - x,y coordinates  
    oled.text(str(line2)[:16], 0, 20)               # each character 8 pixels, then 128/8 = 16 is max 
    oled.show()                                     # used to display  
    sleep(delay)

# ----- 6 Sensor Calibration Functions -------

# Moisture Sensor
def moist_calibrate(soil_value):
    moist_percent = ((dry - soil_value) / (dry - wet)) * 100
    
    if moist_percent > 100:
        return 100
    elif moist_percent < 0:
        return 0
    return round(moist_percent, 2)                     # round value to 2 decimals

# LDR Sensor
def ldr_calibrate(light_value):
    ldr_percent = ((dark - light_value) / (dark - bright)) * 100
    
    if ldr_percent > 100:
        return 100
    elif ldr_percent < 0:
        return 0
    return round(ldr_percent, 2)

# -------- 7 Plant Health Scoring Functions -------------

# Individual Parameter Scoring Function
def parameter_score(value, low, high, step):

    if low <= value <= high:
        return 100
    elif (low - step) <= value < low or \
         high < value <= (high + step):
        return 80
    elif (low - 2 * step) <= value < (low - step) or \
         (high + step) < value <= (high + 2 * step):
        return 60
    elif (low - 3 * step) <= value < (low - 2 * step) or \
         (high + 2 * step) < value <= (high + 3 * step):
        return 40
    elif (low - 4 * step) <= value < (low - 3 * step) or \
         (high + 3 * step) < value <= (high + 4 * step):
        return 20
    return 0

# Overall Health Scoring Function
def health_score(moisture_score, temperature_score, humidity_score, light_score):

    health = (
        moisture_weight * moisture_score +
        temperature_weight * temperature_score +
        humidity_weight * humidity_score +
        light_weight * light_score
    )
    return round(health, 2)

# Health Status Function
def status(health):
    
    if health >= 85:
        return "Excellent"
    elif health >= 70:
        return "Good"
    elif health >= 50:
        return "Average"
    elif health >= 25:
        return "Warning"
    return "Critical"

# ----- 8 Utility Functions ----------

# History Function for storing health scores
def update_history(history, value, limit = history_limit):
    
    history.append(value)
    if len(history) > limit:             # stores 5 values 
        history.pop(0)

# Trend Function for returning plant health trend
def trend(history):

    if len(history) < 5:                 # requires 5 values for trend
        return "Collecting"

    average_previous = (sum(history[:-1]) / (len(history) - 1))    # averages the first 4 values 
    difference = history[-1] - average_previous                    # difference of average and last value

    if difference >= 5:
        return "Improving"
    elif difference <= -5:
        return "Declining"
    return "Stable"

# Health Prediction Function
def predict_health(history):

    if len(history) < 3:          # requires 3 values for prediction         
        return 0

    changes = []
    
    for i in range(1, len(history)):
        changes.append(history[i] - history[i - 1])      # difference of the adjacent elements

    average_change = sum(changes) / len(changes)         # averaging the distance
    predicted_health = (history[-1] + average_change)    # adding the average to last element

    if predicted_health > 100:
        return 100
    elif predicted_health < 0:
        return 0
    return round(predicted_health, 2)

# Limiting Factor Function
def limiting_factor(moisture_score, temperature_score, humidity_score, light_score):

    scores = {                                    # Score dictionary to store different parameter scores
        "Moisture": moisture_score,
        "Temperature": temperature_score,
        "Humidity": humidity_score,
        "Light": light_score
        }

    lowest_score = min(scores.values())         # returns the minimum score

    if lowest_score >= 80:
        return "None"
    return min(scores, key=scores.get)         # returns the key with that minimum score

# Recommendation Function
def recommend(factor):
    if factor == "Moisture":
        return "Adjust Moisture"
    elif factor == "Temperature":
        return "Adjust Temp"
    elif factor == "Humidity":
        return "Adjust Humidity"
    elif factor == "Light":
        return "Adjust Light"
    return "Plant Healthy"

# --------- 9 Firebase Communication Function ----------

def send_to_firebase(
    plant_name,
    moisture,
    temperature,
    humidity,
    light,
    score,
    plant_status,
    plant_trend,
    future_health,
    factor,
    recommendation
):
                                                           # data dictionary for internet transfer
    data = {
        "plant_name": plant_name,
        "moisture": moisture,
        "temperature": temperature,
        "humidity": humidity,
        "light": light,
        "score": score,
        "status": plant_status,
        "trend": plant_trend,
        "future_health": future_health,
        "limiting_factor": factor,
        "recommendation": recommendation
    }

    try:
        response = urequests.patch(
            firebase_url,                                  # patch method - updates the alreeady existing data
            data=ujson.dumps(data),                        # dumps method - converts data dictionary into JSON format   
            headers={"Content-Type": "application/json"}   # headers - extra info to prevent server rejection
        )

        print("Firebase Status:", response.status_code)    # responds with status codes - 200 (success) 
        response.close()

    except Exception as error:
        print("Firebase Error:", error)
        
